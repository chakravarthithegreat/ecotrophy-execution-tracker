rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic auth requirement for everything
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Departments: Read only for all auth users, write only for admin (placeholder)
    match /departments/{deptId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // For V1, allow all auth users to setup
    }
    
    // Boards: Read/Write for all auth users
    match /boards/{boardId} {
      allow read, write: if request.auth != null;
    }
    
    // Tasks: Read/Write for all auth users
    match /tasks/{taskId} {
      allow read, write: if request.auth != null;
    }
  }
}